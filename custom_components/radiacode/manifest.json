{
  "domain": "radiacode",
  "name": "RadiaCode",
  "version": "0.1.0",
  "codeowners": ["@303Bryan"],
  "config_flow": true,
  "dependencies": ["bluetooth"],
  "documentation": "https://github.com/303Bryan/ha-radiacode",
  "integration_type": "device",
  "iot_class": "local_polling",
  "bluetooth": [
    {
      "local_name": "RC-*"
    },
    {
      "local_name": "RadiaCode-*"
    }
  ],
  "requirements": ["bleak-retry-connector>=3.0.0"]
}
